# Date functions: MONTH, YEAR, DATE_TRUNC
statement ok
CREATE TABLE dated_sales (sale_date DATE, amount DOUBLE);

statement ok
INSERT INTO dated_sales VALUES
    ('2023-01-15', 100), ('2023-01-20', 150),
